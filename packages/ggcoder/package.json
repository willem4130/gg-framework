{
  "name": "@kenkaiiii/ggcoder",
  "version": "5.12.0",
  "type": "module",
  "description": "CLI coding agent with OAuth authentication for Anthropic, OpenAI, and Gemini",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kenkaiiii/gg-framework.git",
    "directory": "packages/ggcoder"
  },
  "bin": {
    "ggcoder": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./ui": {
      "import": "./dist/ui/components/index.js",
      "types": "./dist/ui/components/index.d.ts"
    },
    "./ui/theme": {
      "import": "./dist/ui/theme/theme.js",
      "types": "./dist/ui/theme/theme.d.ts"
    },
    "./ui/theme/detect": {
      "import": "./dist/ui/theme/detect-theme.js",
      "types": "./dist/ui/theme/detect-theme.d.ts"
    },
    "./ui/hooks/terminal-size": {
      "import": "./dist/ui/hooks/useTerminalSize.js",
      "types": "./dist/ui/hooks/useTerminalSize.d.ts"
    },
    "./ui/hooks/agent-loop": {
      "import": "./dist/ui/hooks/useAgentLoop.js",
      "types": "./dist/ui/hooks/useAgentLoop.d.ts"
    },
    "./ui/hooks/double-press": {
      "import": "./dist/ui/hooks/useDoublePress.js",
      "types": "./dist/ui/hooks/useDoublePress.d.ts"
    },
    "./ui/hooks/transcript-history": {
      "import": "./dist/ui/hooks/useTranscriptHistory.js",
      "types": "./dist/ui/hooks/useTranscriptHistory.d.ts"
    },
    "./ui/transcript/spacing": {
      "import": "./dist/ui/transcript/spacing.js",
      "types": "./dist/ui/transcript/spacing.d.ts"
    },
    "./ui/transcript/frame": {
      "import": "./dist/ui/transcript/TranscriptItemFrame.js",
      "types": "./dist/ui/transcript/TranscriptItemFrame.d.ts"
    },
    "./ui/terminal-history": {
      "import": "./dist/ui/terminal-history.js",
      "types": "./dist/ui/terminal-history.d.ts"
    },
    "./ui/tool-group-summary": {
      "import": "./dist/ui/tool-group-summary.js",
      "types": "./dist/ui/tool-group-summary.d.ts"
    },
    "./ui/transcript/tool-presentation": {
      "import": "./dist/ui/transcript/tool-presentation.js",
      "types": "./dist/ui/transcript/tool-presentation.d.ts"
    },
    "./ui/terminal-history-format": {
      "import": "./dist/ui/terminal-history-format.js",
      "types": "./dist/ui/terminal-history-format.d.ts"
    },
    "./ui/login": {
      "import": "./dist/ui/login.js",
      "types": "./dist/ui/login.d.ts"
    },
    "./models": {
      "import": "./dist/core/model-registry.js",
      "types": "./dist/core/model-registry.d.ts"
    },
    "./auth": {
      "import": "./dist/core/auth/index.js",
      "types": "./dist/core/auth/index.d.ts"
    },
    "./utils/open-browser": {
      "import": "./dist/utils/open-browser.js",
      "types": "./dist/utils/open-browser.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "node --eval \"fs.rmSync('dist', { recursive: true, force: true })\"",
    "build": "pnpm clean && tsc",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "bench:edit": "tsx src/core/hashline-edit-benchmark.ts",
    "bench:search": "tsx src/core/semantic-search-benchmark.ts",
    "verify:goal:tests": "vitest run src/core/goal-controller.test.ts src/core/goal-engine.test.ts src/core/goal-store.test.ts src/core/goal-integration.test.ts src/core/goal-prerequisites.test.ts src/core/goal-verifier.test.ts src/core/goal-worker.test.ts src/core/goal-worker-dev-server-lifecycle.test.ts src/core/goal-worktree.test.ts src/core/goal-lifecycle-smoke.test.ts src/tools/goals.test.ts src/tools/goal-mode.test.ts src/ui/goal-events.test.ts src/ui/goal-lifecycle-orchestration.test.ts src/ui/goal-overlay.test.ts src/ui/goal-status-bar.test.ts src/system-prompt.test.ts",
    "verify:goal:overhead": "tsx scripts/verify-goal-overhead-harness.ts",
    "goal:overhead-audit": "tsx scripts/verify-goal-overhead-audit.ts",
    "verify:goal:e2e": "pnpm dlx tsx scripts/verify-goal-e2e.ts"
  },
  "dependencies": {
    "@jridgewell/trace-mapping": "^0.3.25",
    "@kenkaiiii/agent-home-sdk": "^0.3.8",
    "@kenkaiiii/gg-agent": "workspace:*",
    "@kenkaiiii/gg-ai": "workspace:*",
    "@kenkaiiii/gg-core": "workspace:*",
    "@kenkaiiii/kencode-search": "^0.1.17",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ansi-regex": "^6.2.2",
    "chalk": "^5.6.2",
    "cli-highlight": "^2.1.11",
    "diff": "^8.0.3",
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.5",
    "ink": "npm:@kenkaiiii/ink@6.8.0-gg.2",
    "lowlight": "^3.3.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "opensrc": "^0.7.2",
    "react": "^19.2.5",
    "sharp": "^0.34.5",
    "string-width": "^8.2.0",
    "strip-ansi": "^7.2.0",
    "typescript": "^6.0.3",
    "typescript-language-server": "^5.3.0",
    "wrap-ansi": "^10.0.0",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^3.6.0",
    "@mozilla/readability": "^0.6.0",
    "linkedom": "^0.18.12",
    "ogg-opus-decoder": "^1.6.13",
    "playwright": "^1.50.0",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "unpdf": "^1.6.2"
  },
  "devDependencies": {
    "@types/hast": "^3.0.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/turndown": "^5.0.6",
    "tsx": "^4.22.3",
    "vitest": "^4.1.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
