{
  "name": "@kenkaiiii/gg-editor",
  "version": "0.7.59",
  "type": "module",
  "description": "CLI video editor agent. Drives DaVinci Resolve and Premiere Pro via API + hotkeys + GUI fallback.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kenkaiiii/gg-framework.git",
    "directory": "packages/gg-editor"
  },
  "bin": {
    "ggeditor": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core/filler-words": {
      "import": "./dist/core/filler-words.js",
      "types": "./dist/core/filler-words.d.ts"
    },
    "./core/clustering": {
      "import": "./dist/core/clustering.js",
      "types": "./dist/core/clustering.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:skills": "node scripts/build-skills.mjs",
    "build:python": "node scripts/copy-python.mjs",
    "build": "node scripts/build-skills.mjs && tsc && node scripts/copy-python.mjs",
    "check": "node scripts/build-skills.mjs && tsc --noEmit",
    "test": "node scripts/build-skills.mjs && vitest run"
  },
  "dependencies": {
    "@kenkaiiii/gg-agent": "workspace:*",
    "@kenkaiiii/gg-ai": "workspace:*",
    "@kenkaiiii/ggcoder": "workspace:*",
    "chalk": "^5.6.2",
    "ink": "^7.0.2",
    "react": "^19.2.5",
    "ws": "^8.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/ws": "^8.5.13",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
