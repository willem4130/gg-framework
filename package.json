{
  "name": "gg-framework",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "lint": "eslint 'packages/*/src/**/*.{ts,tsx}'",
    "lint:fix": "eslint 'packages/*/src/**/*.{ts,tsx}' --fix",
    "format": "prettier --write 'packages/*/src/**/*.{ts,tsx,py}'",
    "format:check": "prettier --check 'packages/*/src/**/*.{ts,tsx}'",
    "test": "pnpm -r test",
    "prepare": "pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript-eslint": "^8.59.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "onnxruntime-node"
    ],
    "overrides": {
      "global-agent": "^4.1.3",
      "ip-address": "^10.1.1"
    },
    "patchedDependencies": {
      "ink@7.0.2": "patches/ink@7.0.2.patch"
    }
  }
}
